PORT=3000

# Set to "production" on the aaPanel server. PM2's ecosystem.config.cjs also sets
# this, but keep it here so `node src/server.js` behaves the same if run directly.
NODE_ENV=production

# On aaPanel install MongoDB from the App Store and connect over localhost, e.g.
#   MONGODB_URI=mongodb://USER:PASS@127.0.0.1:27017/filliptraining
MONGODB_URI=mongodb://localhost:27017/
ACCESS_TOKEN_SECRET=
ACCESS_TOKEN_EXPIRY=

REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

ADMIN_EMAIL=
ADMIN_PHONE=

# WhatsApp Numbers (different per audience)
WHATSAPP_GUEST=        # unenrolled / not logged in
WHATSAPP_ENROLLED=       # enrolled students
WHATSAPP_INSTRUCTOR=     # instructors

# WhatsApp greet/welcome API (sends "welcome + thanks for enrolling" on course enrollment).
# Defaults to the prod endpoint if unset.
WHATSAPP_API_URL=https://whatsapapi.fillipsoftware.com/api/send/greed/message


SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Razorpay (get from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Frontend origin(s) — used for CORS allow-list AND links in emails / affiliate
# referral URLs. Comma-separate to allow more than one (no trailing slash).
# Local dev:  CLIENT_URL=http://localhost:5173
# Production: CLIENT_URL=https://fillipskillacademy.com,https://www.fillipskillacademy.com
CLIENT_URL=http://localhost:5173

# Google Sign-In — OAuth 2.0 Web client ID from Google Cloud Console.
# MUST match the client's VITE_GOOGLE_CLIENT_ID (it's the ID token's audience).
GOOGLE_CLIENT_ID=

# Redis cache (OPTIONAL). Leave unset to run without caching (e.g. local dev).
# In production point at the aaPanel-local Redis, e.g. redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# ── AI chat / assistant ──────────────────────────────────────────────────────
# CHAT_PROVIDER selects which backend the chat uses: "gemini" or "openai".
CHAT_PROVIDER=gemini
CHAT_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=




